# === SmartBiz AI Backend ===

# Application
APP_NAME=SmartBiz AI
APP_VERSION=0.1.0
DEBUG=true
API_V1_PREFIX=/api/v1

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://smartbiz:smartbiz@localhost:5432/smartbiz
DATABASE_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=CHANGE-ME-USE-openssl-rand-hex-64
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# AI (OpenAI)
OPENAI_API_KEY=
AI_MODEL=gpt-4o

# Storage (S3)
S3_BUCKET=
S3_REGION=
