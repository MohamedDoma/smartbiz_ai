## SmartBiz AI — Staging Environment
## Copy to .env and fill in secrets

APP_NAME=SmartBiz
APP_ENV=staging
APP_KEY=
APP_DEBUG=false
APP_URL=https://staging.smartbiz.ai

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily,stderr
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=smartbiz
DB_USERNAME=smartbiz
DB_PASSWORD=CHANGE_ME

SESSION_DRIVER=redis
SESSION_LIFETIME=120

QUEUE_CONNECTION=redis
CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@smartbiz.ai"
MAIL_FROM_NAME="${APP_NAME}"

STRIPE_KEY=sk_test_xxx
STRIPE_SECRET=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

AI_PROVIDER=openai
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

SUPER_ADMIN_EMAIL=admin@smartbiz.ai
