# SmartBiz production environment template
# Copy to backend/.env.production on the server. Never commit the real file.

APP_NAME=SmartBiz
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.example.com
FRONTEND_URL=https://app.example.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_MAINTENANCE_DRIVER=cache
APP_MAINTENANCE_STORE=redis
# Comma-separated IPs/CIDRs of a real upstream proxy. Never use *.
TRUSTED_PROXIES=

LOG_CHANNEL=production
LOG_LEVEL=warning
LOG_DAILY_DAYS=14

# Container and release settings
NGINX_PORT=80
SMARTBIZ_IMAGE_TAG=latest
SMARTBIZ_OPTIMIZE_ON_START=true
APP_MEMORY_LIMIT=512m
WORKER_MEMORY_LIMIT=384m
SCHEDULER_MEMORY_LIMIT=192m
NGINX_MEMORY_LIMIT=128m
POSTGRES_MEMORY_LIMIT=768m
POSTGRES_SHM_SIZE=256m
REDIS_MEMORY_LIMIT=384m
REDIS_MAXMEMORY=256mb

# Backup and operational monitoring
BACKUP_PATH=/var/backups/smartbiz
BACKUP_VOLUME_SOURCE=backup_data
BACKUP_RETENTION_DAYS=30
BACKUP_MAX_AGE_HOURS=26
BACKUP_MIN_FREE_MB=1024
BACKUP_TIMEOUT_SECONDS=1800
BACKUP_VERIFY_ARCHIVE=true
# Optional Laravel filesystem disk for a second/off-server copy.
BACKUP_MIRROR_DISK=
BACKUP_MIRROR_PREFIX=smartbiz
BACKUP_MIRROR_REQUIRED=false
DEPLOY_BACKUP_BEFORE_MIGRATE=true
DEPLOY_FILES_BACKUP_BEFORE_READINESS=true

OPS_DISK_PATH=/var/www/html/storage
OPS_DISK_WARNING_FREE_MB=1024
OPS_DISK_CRITICAL_FREE_MB=256
OPS_QUEUE_PENDING_WARNING=100
OPS_QUEUE_PENDING_CRITICAL=500
OPS_QUEUE_FAILED_WARNING=1
OPS_QUEUE_FAILED_CRITICAL=10
OPS_QUEUE_HEARTBEAT_MAX_AGE=180
OPS_SCHEDULER_HEARTBEAT_MAX_AGE=180
OPS_ALERT_WEBHOOK_URL=
OPS_ALERT_TIMEOUT_SECONDS=10
OPS_ALERT_COOLDOWN_MINUTES=30

# Queue worker settings
REDIS_QUEUE=default
REDIS_QUEUE_RETRY_AFTER=120
REDIS_QUEUE_BLOCK_FOR=5
QUEUE_AFTER_COMMIT=true
QUEUE_WORKER_SLEEP=3
QUEUE_WORKER_TRIES=3
QUEUE_WORKER_BACKOFF=60
QUEUE_WORKER_TIMEOUT=90
QUEUE_WORKER_MAX_TIME=3600
QUEUE_WORKER_MAX_JOBS=1000
QUEUE_WORKER_MEMORY=256

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=smartbiz
DB_USERNAME=smartbiz
DB_PASSWORD=
DB_SSLMODE=prefer

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_DOMAIN=.example.com
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_PARTITIONED_COOKIE=false
SANCTUM_STATEFUL_DOMAINS=app.example.com
CORS_ALLOWED_ORIGINS=https://app.example.com

MAIL_MAILER=log
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="${APP_NAME}"
RESEND_API_KEY=
MAIL_LOGO_URL="${APP_URL}/images/smartbiz-logo.png"

AI_ENABLED=true
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o-mini
OPENAI_SMART_MODEL=gpt-4o
OPENAI_TIMEOUT=30
AI_MONTHLY_BUDGET_USD=30
AI_DAILY_MESSAGE_LIMIT=200
AI_MONTHLY_MESSAGE_LIMIT=3000
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# Current payment flow: activation cards + cash/bank-transfer approval.
# Stripe is optional and intentionally disabled until online payments are added.
STRIPE_ENABLED=false
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

SUPER_ADMIN_EMAIL=
